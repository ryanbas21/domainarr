{
  "name": "domainarr",
  "version": "0.0.0",
  "description": "DNS sync CLI for Pi-hole and Cloudflare",
  "type": "module",
  "bin": {
    "domainarr": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "prepare": "effect-language-service patch",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "dns",
    "pihole",
    "pi-hole",
    "cloudflare",
    "effect",
    "cli",
    "sync",
    "local-dns"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanbas21/domainarr.git"
  },
  "homepage": "https://github.com/ryanbas21/domainarr#readme",
  "bugs": {
    "url": "https://github.com/ryanbas21/domainarr/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "cloudflare": "^5.2.0",
    "effect": "^3.19.19"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@effect/language-service": "^0.80.0",
    "@effect/vitest": "^0.27.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
